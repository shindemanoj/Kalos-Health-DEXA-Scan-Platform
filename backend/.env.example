# Server
PORT=4000
NODE_ENV=development

# PostgreSQL — use a connection string or individual vars
DATABASE_URL=postgresql://postgres:password@localhost:5432/kalos

# Auth
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-...
MEMBER_GPT_API_URL=http://localhost:5174   # update to deployed URL

# File uploads (local dev — swap for S3 in prod)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
